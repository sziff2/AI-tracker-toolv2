# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:changeme@db:5432/research_agent
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:changeme@db:5432/research_agent
POSTGRES_PASSWORD=changeme

# ── Redis / Celery (optional — background jobs fall back to in-process) ──
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── LLM ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.0

# ── Storage ──────────────────────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_BASE_PATH=./storage

# ── API / Security ───────────────────────────────────────────────
DEBUG=false
MAX_UPLOAD_SIZE_MB=50
APP_BASE_URL=https://ai-tracker-tool-production.up.railway.app

# ── Optional integrations ────────────────────────────────────────
SLACK_WEBHOOK_URL=
EODHD_API_KEY=
